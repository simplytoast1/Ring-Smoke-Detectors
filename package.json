{
  "name": "homebridge-ring-smoke-detectors",
  "displayName": "Ring Smoke Detectors",
  "version": "1.2.0",
  "description": "Homebridge plugin for Kidde/Ring smart smoke and CO detectors (hubless WiFi models)",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "config.schema.json"
  ],
  "scripts": {
    "build": "swc src -d dist --strip-leading-paths && rm -rf dist/homebridge-ui/public && cp -r src/homebridge-ui/public dist/homebridge-ui/public",
    "watch": "swc src -d dist --strip-leading-paths --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "ring",
    "kidde",
    "smoke-detector",
    "carbon-monoxide"
  ],
  "author": "simplytoast1",
  "license": "MIT",
  "homepage": "https://github.com/simplytoast1/Ring-Smoke-Detectors#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simplytoast1/Ring-Smoke-Detectors.git"
  },
  "bugs": {
    "url": "https://github.com/simplytoast1/Ring-Smoke-Detectors/issues"
  },
  "engines": {
    "node": "^20 || ^22 || ^24 || ^25",
    "homebridge": ">=1.8.0 || ^2.0.0-beta.0"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^1.0.0",
    "rxjs": "^7.8.2",
    "undici": "^7.19.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.11.0",
    "@types/node": "^22.0.0",
    "homebridge": "^2.0.0-beta.0",
    "typescript": "^5.9.0"
  }
}
